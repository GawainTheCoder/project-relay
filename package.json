{
  "name": "project-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A personal, evidence-backed AI infrastructure intelligence dashboard.",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "backup": "tsx scripts/backup-relay.ts",
    "build": "vite build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "dev": "concurrently --kill-others --names web,api --prefix-colors cyan,magenta \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "lint": "eslint . --max-warnings 0",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.6",
    "@mozilla/readability": "0.6.0",
    "dotenv": "17.4.2",
    "fast-xml-parser": "5.9.3",
    "hono": "4.12.27",
    "linkedom": "0.18.12",
    "lucide-react": "1.21.0",
    "openai": "6.45.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.1",
    "@types/mozilla__readability": "0.4.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vitest": "4.1.9"
  }
}
