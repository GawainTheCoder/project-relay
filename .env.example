# The API binds to loopback by default so it is not exposed to the local network.
HOST=127.0.0.1
PORT=8787
# Keep this list on loopback unless you intentionally expose Relay elsewhere.
RELAY_ALLOWED_HOSTS=127.0.0.1,localhost,::1
RELAY_REFRESH_MAX_ITEMS=6
# Keep false for a clean personal workspace. Set true only to load demo updates.
RELAY_DEMO_DATA=false

# OpenAI powers evidence extraction, thesis impact analysis, and daily synthesis.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_SYNTHESIS_MODEL=gpt-5.5
# Keep true to retain Responses and searchable metadata in the OpenAI Platform.
OPENAI_STORE_RESPONSES=true
